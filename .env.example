# Member portal URL
BASE_URL=https://myezra-staging.ezra.com

# API base (used by global-setup)
API_BASE_URL=https://stage-api.ezra.com

# Set to false in CI when the staging calendar has no open slots
# Tests guarded by hasStagingSlots will skip rather than fail
STAGING_HAS_SLOTS=true

# Staging test account credentials — provided separately
MEMBER_EMAIL=
MEMBER_PASSWORD=
MEMBER_PHONE=
MEMBER_LINK_PHONE=
MEMBER_FIRST_NAME=
MEMBER_LAST_NAME=
